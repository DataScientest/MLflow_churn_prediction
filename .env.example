# ---- MLflow Configuration ----
# Point all MLflow clients to the central tracking server
MLFLOW_TRACKING_URI=http://localhost:5000

# ---- PostgreSQL (used by MLflow server, NOT by clients directly) ----
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow

# ---- LLM Provider Configuration ----
# Options: openai, ollama
LLM_PROVIDER=ollama
LLM_MODEL=gemma3:4b

# OpenAI Configuration (Required if LLM_PROVIDER=openai)

# LiteLLM
# LITELLM_KEY=

# Ollama Configuration (Required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Agent Service
AGENT_PORT=8080
